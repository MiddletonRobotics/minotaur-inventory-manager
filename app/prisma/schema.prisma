generator client {
    provider = "prisma-client"
    output = "./generated"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    STANDARD
    ADMIN
}

model User {
    id Int @id @default(autoincrement())
    type Role @default(STANDARD)
    firstName String @unique
    lastName String @unique
    createdAt DateTime @default(now())
}