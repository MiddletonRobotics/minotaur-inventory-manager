generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STANDARD
  MANAGER
  ADMINISTRATOR
}

enum Vendor {
  WCP
  VEX
  ANDYMARK
  THRIFTYBOT
  REV
  CTRE
  MCMASTER
  LIMELIGHT
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id        Int      @id @default(dbgenerated("floor(random() * 90000000 + 10000000)::int"))
  type      Role     @default(STANDARD)
  firstName String
  lastName  String
  pwdHash   String
  createdAt DateTime @default(now())

  projectsCreated   Project[]         @relation("ProjectCreatedBy")
  checkoutsCreated  ProjectCheckout[] @relation("CheckoutCheckedOutBy")
  checkoutsModified ProjectCheckout[] @relation("CheckoutModifiedBy")

  @@unique([firstName, lastName])
}

model Category {
  id        Int        @id @default(dbgenerated("floor(random() * 90000000 + 10000000)::int"))
  name      String     @unique
  parentId  Int?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  items     Item[]
  createdAt DateTime   @default(now())

  @@unique([name, parentId])
}

model Item {
  id          Int               @id @default(dbgenerated("floor(random() * 90000000 + 10000000)::int"))
  name        String
  partNumber  String            @unique
  description String
  categoryId  Int
  category    Category          @relation(fields: [categoryId], references: [id])
  vendor      Vendor
  material    String?
  location    String?
  quantity    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  checkouts   ProjectCheckout[]

  @@index([categoryId])
  @@index([partNumber])
}

model Project {
  id            Int               @id @default(dbgenerated("floor(random() * 90000000 + 10000000)::int"))
  name          String            @unique
  description   String?
  status        ProjectStatus     @default(ACTIVE)
  checkouts     ProjectCheckout[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdById   Int
  createdByUser User              @relation("ProjectCreatedBy", fields: [createdById], references: [id])
}

model ProjectCheckout {
  id                 Int      @id @default(dbgenerated("floor(random() * 90000000 + 10000000)::int"))
  projectId          Int
  project            Project  @relation(fields: [projectId], references: [id])
  partId             Int
  part               Item     @relation(fields: [partId], references: [id])
  quantityCheckedOut Int
  note               String?
  checkedOutAt       DateTime @default(now())
  checkedOutById     Int
  checkedOutBy       User     @relation("CheckoutCheckedOutBy", fields: [checkedOutById], references: [id])
  lastModifiedAt     DateTime @updatedAt
  lastModifiedById   Int?
  lastModifiedBy     User?    @relation("CheckoutModifiedBy", fields: [lastModifiedById], references: [id])

  @@unique([projectId, partId])
  @@index([projectId])
  @@index([partId])
}