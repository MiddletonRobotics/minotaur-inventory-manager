generator client {
    provider = "prisma-client"
    output = "./generated"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    STANDARD
    ADMIN
}

model User {
    id Int @id @default(autoincrement())
    type Role @default(STANDARD)
    firstName String 
    lastName String 
    pwdHash String
    createdAt DateTime @default(now())
    
    @@unique([firstName, lastName])
}